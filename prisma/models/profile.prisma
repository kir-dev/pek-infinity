model Profile {
  userId           String                @id @unique
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName        String?
  lastName         String?
  nickname         String?
  avatar           String?               // Derived from username or nickname (emoji/initials/avatar URL)
  room             String?
  dormitory        Dormitory?            @default(UNKNOWN)
  gender           Gender?               @default(UNKNOWN)
  studentStatus    StudentStatus?        @default(UNKNOWN)
  contacts         Contact[]
  updatedAt        DateTime              @updatedAt
}

enum Dormitory {
  KARMAN
  TETENY
  SCH
  BAROSS
  BERCSENYI
  VASARHELYI
  EXTERNAL
  UNKNOWN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  OTHER
  UNKNOWN
}
